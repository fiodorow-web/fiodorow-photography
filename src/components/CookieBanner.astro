<!-- Cookie Consent Banner — compact, translucent -->
<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[60] transform translate-y-full transition-transform duration-500 ease-out"
>
  <div class="bg-charcoal/75 backdrop-blur-md text-white px-4 py-3">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[0.65rem] md:text-xs text-white/80 text-center sm:text-left leading-snug">
        Używamy plików cookies, aby zapewnić prawidłowe działanie strony i analizować ruch. 
        <a href="/polityka-prywatnosci" class="text-olive-dark hover:text-white underline underline-offset-2 transition-colors">
          Polityka prywatności
        </a>
      </p>
      <div class="flex items-center gap-2 flex-shrink-0">
        <button
          id="cookie-reject"
          class="px-6 py-3 border border-white/40 text-white text-xs tracking-[0.15em] uppercase rounded hover:bg-white/10 transition-colors font-medium"
        >
          Odrzucam
        </button>
        <button
          id="cookie-accept"
          class="px-6 py-3 bg-white text-charcoal text-xs tracking-[0.15em] uppercase rounded hover:bg-cream transition-colors font-medium"
        >
          Akceptuję
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  const hideBanner = () => {
    banner?.classList.remove('translate-y-0');
    banner?.classList.add('translate-y-full');
  };

  // Show only until the user has made a choice — either way.
  const decided =
    localStorage.getItem('cookies-accepted') || localStorage.getItem('cookies-rejected');

  if (!decided) {
    setTimeout(() => {
      banner?.classList.remove('translate-y-full');
      banner?.classList.add('translate-y-0');
    }, 1500);
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.removeItem('cookies-rejected');
    localStorage.setItem('cookies-accepted', 'true');
    document.dispatchEvent(new Event('cookies-accepted'));
    hideBanner();
  });

  rejectBtn?.addEventListener('click', () => {
    localStorage.removeItem('cookies-accepted');
    localStorage.setItem('cookies-rejected', 'true');
    document.dispatchEvent(new Event('cookies-rejected'));
    hideBanner();
  });
</script>
