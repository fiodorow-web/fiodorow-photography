<!-- Cookie Consent Banner — compact, translucent -->
<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[60] transform translate-y-full transition-transform duration-500 ease-out"
>
  <div class="bg-charcoal/75 backdrop-blur-md text-white px-4 py-3">
    <div class="max-w-5xl mx-auto flex items-center justify-between gap-3">
      <p class="text-[0.65rem] md:text-xs text-white/80 leading-snug">
        Cookies pomagają nam analizować ruch. 
        <a href="/polityka-prywatnosci" class="text-olive-dark hover:text-white underline underline-offset-2 transition-colors">
          Więcej
        </a>
      </p>
      <button
        id="cookie-accept"
        class="px-4 py-1.5 bg-white text-charcoal text-[0.6rem] tracking-[0.15em] uppercase rounded hover:bg-cream transition-colors flex-shrink-0 font-medium"
      >
        OK
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');

  // Check if user already accepted
  if (!localStorage.getItem('cookies-accepted')) {
    // Show banner after a short delay
    setTimeout(() => {
      banner?.classList.remove('translate-y-full');
      banner?.classList.add('translate-y-0');
    }, 1500);
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookies-accepted', 'true');
    banner?.classList.remove('translate-y-0');
    banner?.classList.add('translate-y-full');
  });
</script>
