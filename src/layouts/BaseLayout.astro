---
import "../styles/global.css";
import CookieBanner from "../components/CookieBanner.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  breadcrumbs?: { name: string; href: string }[];
  noindex?: boolean;
}

const {
  title,
  description = "Fiodorow Photography - Profesjonalna fotografia ślubna i portretowa. Siedlce, Białystok, Warszawa.",
  image = "/og-image.jpg",
  breadcrumbs,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const breadcrumbSchema = breadcrumbs
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Strona główna",
          item: "https://fiodorowphotography.pl/",
        },
        ...breadcrumbs.map((crumb, i) => {
          const isLast = i === breadcrumbs.length - 1;
          return {
            "@type": "ListItem",
            position: i + 2,
            name: crumb.name,
            ...(isLast ? {} : { item: `https://fiodorowphotography.pl${crumb.href}` }),
          };
        }),
      ],
    }
  : null;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://cdn.sanity.io" />

    <!-- Fonts loaded locally via Fontsource -->

    <title>{title}</title>

    <meta name="generator" content={Astro.generator} />

    <!-- Schema.org for Photographer / LocalBusiness -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": ["Photographer", "LocalBusiness"],
        "@id": "https://fiodorowphotography.pl/#photographer",
        name: "Fiodorow Photography | Fotografia Ślubna",
        image: new URL(image, Astro.site).href,
        logo: "https://fiodorowphotography.pl/logo-dark.webp",
        description: description,
        address: {
          "@type": "PostalAddress",
          streetAddress: "Prymasa Stefana Wyszyńskiego",
          addressLocality: "Siedlce",
          addressRegion: "Mazowieckie",
          postalCode: "08-110",
          addressCountry: "PL",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: 52.1676,
          longitude: 22.2903,
        },
        priceRange: "$$",
        telephone: "+48 660 872 121",
        url: "https://fiodorowphotography.pl",
        hasMap: "https://maps.google.com/?cid=1555365222895602722",
        areaServed: [
          { "@type": "City", name: "Siedlce" },
          { "@type": "City", name: "Warszawa" },
          { "@type": "City", name: "Białystok" },
          { "@type": "City", name: "Łuków" },
          { "@type": "City", name: "Mińsk Mazowiecki" },
          { "@type": "City", name: "Sokołów Podlaski" },
          { "@type": "City", name: "Węgrów" },
          { "@type": "City", name: "Garwolin" },
        ],
        openingHoursSpecification: {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday",
          ],
          opens: "00:00",
          closes: "23:59",
        },
        aggregateRating: {
          "@type": "AggregateRating",
          ratingValue: "5.0",
          reviewCount: "53",
          bestRating: "5",
          worstRating: "1",
        },
        sameAs: [
          "https://maps.google.com/?cid=1555365222895602722",
          "https://www.instagram.com/fiodorow_photography",
          "https://www.facebook.com/fiodorowphotography",
        ],
      })}
    />
    {
      breadcrumbSchema && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(breadcrumbSchema)}
        />
      )
    }
  </head>
  <body class="antialiased">
    <slot />
    <CookieBanner />
    <!-- Google Consent Mode v2 — default denied before user consent -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'analytics_storage': 'denied',
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'wait_for_update': 500
      });
    </script>
    <script>
      function loadAnalytics() {
        if (document.querySelector('[data-analytics-loaded]')) return;
        const va = document.createElement('script');
        va.src = '/_vercel/insights/script.js';
        va.defer = true;
        va.dataset.analyticsLoaded = '';
        document.head.appendChild(va);
        const si = document.createElement('script');
        si.src = '/_vercel/speed-insights/script.js';
        si.defer = true;
        document.head.appendChild(si);
        // Google Analytics 4
        const ga = document.createElement('script');
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-YVBD3JPM7N';
        ga.async = true;
        document.head.appendChild(ga);
        ga.onload = () => {
          gtag('js', new Date());
          gtag('config', 'G-YVBD3JPM7N');
        };
        // Update consent to granted
        gtag('consent', 'update', {
          'analytics_storage': 'granted',
          'ad_storage': 'granted',
          'ad_user_data': 'granted',
          'ad_personalization': 'granted'
        });
      }
      if (localStorage.getItem('cookies-accepted')) {
        loadAnalytics();
      }
      document.addEventListener('cookies-accepted', loadAnalytics);
    </script>

    <!-- Global Scroll-Reveal Animation Observer -->
    <script>
      const initRevealObserver = () => {
        const revealElements = document.querySelectorAll(".reveal");
        if (!revealElements.length) return;

        // Respect reduced motion preference
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          revealElements.forEach((el) => el.classList.add("active"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            root: null,
            rootMargin: "0px 0px -40px 0px",
            threshold: 0.1,
          },
        );

        revealElements.forEach((el) => observer.observe(el));
      };

      // Run on initial load
      document.addEventListener("DOMContentLoaded", initRevealObserver);

      // Re-run on Astro page navigation (View Transitions)
      document.addEventListener("astro:page-load", initRevealObserver);
    </script>
  </body>
</html>
