---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="404 — Strona nie znaleziona | Fiodorow Photography"
  description="Strona, której szukasz, nie istnieje. Wróć na stronę główną."
>
  <Header currentPath="" />

  <main class="pt-32 pb-20 md:pt-40 md:pb-32 bg-cream min-h-[70vh] flex items-center">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <span class="font-serif text-8xl md:text-9xl text-olive/20 block mb-4">404</span>
      <h1 class="font-serif text-2xl md:text-3xl tracking-[0.15em] uppercase text-charcoal mb-6">
        Strona nie <i class="font-light italic text-olive">znaleziona</i>
      </h1>
      <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-10 max-w-md mx-auto">
        Przepraszamy, ale strona, której szukasz, nie istnieje lub została przeniesiona.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">
          Strona główna
        </a>
        <a href="/portfolio" class="btn-primary border-charcoal text-charcoal hover:bg-charcoal hover:text-white">
          Portfolio
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
