---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog | Fiodorow Photography",
  "description": "Porady fotograficzne, inspiracje i wskazówki dla par planujących ślub. Fotografia ślubna, sesje narzeczeńskie, plenerowe.",
  "url": "https://fiodorowphotography.pl/blog",
  "publisher": {
    "@type": "Organization",
    "name": "Fiodorow Photography",
    "url": "https://fiodorowphotography.pl"
  }
};
---

<BaseLayout
  title="Blog | Fiodorow Photography – Porady Fotograficzne i Inspiracje"
  description="Porady fotograficzne, inspiracje ślubne i wskazówki dla par. Dowiedz się, jak przygotować się do sesji, wybrać lokalizację i zaplanować dzień ślubu."
  breadcrumbs={[{ name: "Blog", href: "/blog" }]}
>
  <Header currentPath="/blog" />

  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 md:pt-40 md:pb-20 bg-white">
    <div class="max-w-4xl mx-auto px-6 md:px-12 text-center">
      <div class="reveal reveal-up">
        <span class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Blog</span>
        <h1 class="font-serif text-4xl md:text-5xl tracking-[0.1em] uppercase mb-6 text-charcoal">
          Porady <i class="font-light italic text-olive">& inspiracje</i>
        </h1>
        <p class="text-charcoal-light text-sm md:text-base leading-relaxed max-w-2xl mx-auto">
          Dzielimy się wiedzą, doświadczeniem i inspiracjami. Znajdziesz tu praktyczne porady dotyczące sesji zdjęciowych, przygotowań do ślubu i nie tylko.
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="pb-20 md:pb-32 bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10 reveal-stagger">
        {sortedPosts.map((post, index) => (
          <article class={`group reveal reveal-up ${index === 0 ? '' : `reveal-d${Math.min(index, 5)}`}`}>
            <a href={`/blog/${post.id}`} class="block">
              <!-- Image -->
              <div class="relative overflow-hidden mb-6 aspect-[4/3]">
                <img
                  src={post.data.image}
                  alt={post.data.imageAlt}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading={index < 3 ? "eager" : "lazy"}
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-500"></div>
              </div>

              <!-- Content -->
              <div class="space-y-3">
                <!-- Meta -->
                <div class="flex items-center gap-3 text-xs text-charcoal-light">
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  <span class="w-1 h-1 bg-olive rounded-full"></span>
                  <span>{post.data.readingTime} czytania</span>
                </div>

                <!-- Title -->
                <h2 class="blog-card-title font-serif text-charcoal group-hover:text-olive transition-colors duration-300 leading-snug">
                  {post.data.title}
                </h2>

                <!-- Description -->
                <p class="text-charcoal-light text-sm leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>

                <!-- Read More -->
                <span class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-olive font-medium pt-2 group-hover:gap-3 transition-all duration-300">
                  Czytaj więcej
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 md:py-24 bg-cream-dark">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="section-title mb-6 reveal reveal-up">
        Macie <i class="font-light italic text-olive font-serif">pytania</i>?
      </h2>
      <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-10 max-w-xl mx-auto reveal reveal-up reveal-d1">
        Jeśli nie znaleźliście odpowiedzi na swoje pytania w naszych artykułach, chętnie porozmawiamy osobiście.
      </p>
      <a href="/kontakt" class="btn-primary reveal reveal-up reveal-d2">
        Skontaktuj się
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
