    <div class="max-w-[820px] mx-auto">
      <div class="reveal reveal-up text-center mx-auto mb-[52px]">
        <span class="block font-sans text-xs font-bold tracking-[.22em] uppercase text-olive mb-[18px]">
          FAQ
        </span>
        <h2 class="font-serif font-normal uppercase tracking-[.12em] text-charcoal text-[clamp(28px,3.8vw,42px)] leading-[1.15]">
          Najczęstsze
          <span style="font-style:italic;font-weight:300;color:var(--color-olive);text-transform:uppercase;letter-spacing:.02em">pytania</span>
        </h2>
      </div>
      <div class="reveal reveal-up reveal-d1 flex flex-col gap-[14px]">
        {
          faq.map((item) => (
            <details class="bg-white border border-charcoal/10 rounded-[2px] px-7 py-6 group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="font-serif font-medium text-[18px] text-charcoal m-0">{item.q}</h3>
                <span class="text-olive text-[24px] font-light flex-shrink-0 transition-transform duration-300 group-open:rotate-45">
                  +
                </span>
              </summary>
              <p class="font-sans font-light text-charcoal-light text-[14.5px] leading-[1.75] mt-4 pt-4 border-t border-charcoal/10">
                {item.a}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FOTOBUDKA W TWOIM MIEŚCIE -->
