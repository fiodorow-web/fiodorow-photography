          gallery.map((img) => (
            <Image
              src={img.src}
              alt={img.alt}
              class="w-full rounded-[2px] block object-cover aspect-[3/2]"
              style="box-shadow:0 14px 30px rgba(45,40,30,.1)"
              width={500}
              height={333}
              loading="lazy"
              format="webp"
              quality={78}
              widths={[320, 480, 700, 1000]}
              sizes="(max-width: 700px) calc(100vw - 48px), (max-width: 1100px) 33vw, 350px"
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
