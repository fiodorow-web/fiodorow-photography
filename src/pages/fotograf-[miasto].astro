---

<BaseLayout
  title={`Fotograf ślubny ${city.name} | Fiodorow Photography`}
  description={city.metaDescription}
  breadcrumbs={[{ name: `Fotograf ${city.name}`, href: `/fotograf-${miasto}` }]}
>
  <Header />

  <!-- Hero -->
  <section
    class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden"
  >
    <div class="absolute inset-0">
      <img
        src={city.heroImage}
        alt={`Fotograf ślubny w ${city.nameLocative} – sesja plenerowa`}
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="hero-overlay"></div>
    </div>

    <div class="relative z-10 text-center text-white px-6 reveal reveal-up">
      <span class="text-xs tracking-[0.3em] uppercase opacity-80 mb-4 block">
        Województwo {city.region}
      </span>
      <h1
        class="font-serif text-4xl md:text-6xl font-light tracking-[0.15em] uppercase"
      >
        Fotograf ślubny<br /><span class="text-olive-light"
          >w {city.nameLocative}</span
        >
      </h1>
      <p
        class="mt-6 text-sm md:text-base text-white/80 max-w-xl mx-auto leading-relaxed"
      >
        Naturalny reportaż ślubny, sesje narzeczeńskie i portrety. Duet
        fotografów z pasją do uwieczniania emocji.
      </p>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-20 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
      >
        <div class="reveal reveal-up">
          <span
            class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block"
            >O nas w {city.nameLocative}</span
          >
          <h2 class="section-title mb-6">
            Fotograf ślubny w {city.nameLocative}
          </h2>
          {
            city.aboutParagraphs.map((paragraph) => (
              <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-4">
                {paragraph}
              </p>
            ))
          }

          <!-- Highlights -->
          <ul class="space-y-3 mb-8 mt-6">
            {
              city.highlights.map((highlight) => (
                <li class="flex items-center gap-3 text-sm text-charcoal-light">
                  <span class="w-2 h-2 bg-olive rounded-full flex-shrink-0" />
                  {highlight}
                </li>
              ))
            }
          </ul>

          <a href="/kontakt" class="btn-primary"> Zapytaj o termin </a>
        </div>

        <div class="grid grid-cols-2 gap-4 reveal reveal-up reveal-d1">
          <img
            src={city.gridImages[0]}
            alt={`Sesja ślubna w ${city.nameLocative} – para młoda`}
            class="w-full h-64 object-cover rounded-sm"
            loading="lazy"
