---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import siedlceHeroimg from "../assets/pseo/siedlce/fotograf-slubny-siedlce-sesja-plenerowa.jpg";
import siedlceGridImg1 from "../assets/pseo/siedlce/sesja-slubna-siedlce-para-mloda.jpg";
import siedlceGridImg2 from "../assets/pseo/siedlce/fotografia-portretowa-siedlce-plener.jpg";
import warszawaHeroimg from "../assets/pseo/warszawa/fotograf-slubny-warszawa-sesja-plenerowa.jpg";
import warszawaGridImg1 from "../assets/pseo/warszawa/sesja-slubna-warszawa-para-mloda.jpg";
import warszawaGridImg2 from "../assets/pseo/warszawa/fotografia-portretowa-warszawa-plener.jpg";
import bialystokHeroimg from "../assets/pseo/bialystok/fotograf-slubny-bialystok-sesja-plenerowa.jpg";
import bialystokGridImg1 from "../assets/pseo/bialystok/sesja-slubna-bialystok-para-mloda.jpg";
import bialystokGridImg2 from "../assets/pseo/bialystok/fotografia-portretowa-bialystok-plener.jpg";

export function getStaticPaths() {
  const cities = {
    siedlce: {
      name: "Siedlce",
      nameLocative: "Siedlcach",
      nameGenitive: "Siedlec",
      nameAdjective: "siedlecki",
      region: "Mazowieckie",
      postalCode: "08-110",
      metaDescription:
        "Fotograf ślubny w Siedlcach ✦ Naturalna fotografia ślubna, sesje narzeczeńskie i poślubne. Duet fotografów z Siedlec. Zadzwoń: +48 660 872 121",
      aboutParagraphs: [
        "To nasze rodzinne miasto – tu zaczynała się nasza fotograficzna przygoda i tu mamy swoją bazę. Znamy każdy zakątek okolicy, który sprawdzi się jako tło do sesji ślubnej, narzeczeńskiej czy portretowej. Od malowniczego Parku Aleksandria, aż po okoliczne pola i lasy.",
        "Znamy wiele lokalnych sal weselnych, dzięki temu mamy pogląd na warunki oświetleniowe i najlepsze punkty do zdjęć. Nie tracimy czasu na rozpoznanie terenu – od pierwszej minuty skupiamy się na Was i Waszych emocjach. ",
        "Realizujemy sesje na terenie całego Mazowsza wschodniego – dojeżdżamy do Łukowa, Mińska Mazowieckiego, Sokołowa Podlaskiego, Węgrowa i Garwolina bez dodatkowych kosztów dojazdu.",
      ],
      serviceDescriptions: {
        wedding:
          "Kompletny reportaż z Waszego ślubu – od przygotowań w domu, przez ceremonię w kościele czy USC, aż po szaloną zabawę weselną. Znamy lokalne sale weselne i kościoły, więc wiemy, jak uchwycić najlepsze kadry w każdym z nich.",
        engagement:
          "Sesja narzeczeńska w najpiękniejszych plenerach okolicy. Park Aleksandria, nadrzeczne ścieżki czy malownicze łąki – dobierzemy miejsce idealne dla Was. To też świetna okazja, żebyśmy się poznali przed wielkim dniem.",
        postwedding:
          "Wasza miłość zasługuje na wyjątkową oprawę. Sesja poślubna to nie tylko piękne kadry, ale przede wszystkim wspólny czas, emocje i atmosfera, w której możecie być sobą. Razem wybierzemy miejsce, które najlepiej odda Wasz charakter.",
      },
      faq: [
        {
          question:
            "Czy dojeżdżacie na śluby w okolice Siedlec bez dodatkowych opłat?",
          answer:
            "Tak! Dojazd w promieniu ok. 100 km (m.in. Łuków, Mińsk Mazowiecki, Sokołów Podlaski, Węgrów, Garwolin, Warszawa) jest wliczony w cenę pakietu. Siedlce to nasza baza, więc znamy okolicę doskonale. Przy dalszych lokalizacjach doliczamy jedynie koszty paliwa.",
        },
        {
          question: "Jak długo czeka się na zdjęcia ślubne po weselu?",
          answer:
            "Pełna, profesjonalnie przygotowana galeria jest gotowa w ciągu 3 miesięcy od dnia ślubu. Każde zdjęcie jest starannie obrabiane w naszym autorskim stylu — naturalnym, ciepłym i pełnym emocji. Galeria udostępniana jest online z możliwością pobrania w pełnej rozdzielczości.",
        },
        {
          question: "Gdzie najlepiej zrobić sesję narzeczeńską w Siedlcach?",
          answer:
            "Nasze ulubione lokalizacje to Park Aleksandria, młyn w Stoku Wiśniewskim, okoliczne lasy i łąki. Świetnie sprawdzają się też siedleckie wydmy i Zalew Siedlecki. Możemy wybrać się z Wami również na sesję w stylu miejskim po uliczkach centrum. Chętnie pomożemy dobrać miejsce idealnie pasujące do Waszego stylu i pory roku.",
        },
        {
          question: "Czy fotografujecie również śluby cywilne?",
          answer:
            "Oczywiście! Fotografujemy zarówno śluby kościelne, jak i cywilne w USC oraz humanistyczne w plenerze. Każda forma ceremonii jest dla nas tak samo ważna i piękna. Mamy doświadczenie z różnymi urzędami i salami w okolicach Siedlec, więc wiemy, jak najlepiej uchwycić każdy moment niezależnie od miejsca.",
        },
      ],
      localPlaces: [
        "Park Aleksandria",
        "Uliczki miasta",
        "Okoliczne lasy",
        "Młyn w Stoku Wiśniewskim",
        "Pałac w Patrykozach",
        "Siedleckie wydmy",
        "Zalew siedlecki",
      ],
      highlights: [
        "Nasz dom — znamy każdy plener w okolicy",
        "Brak kosztów dojazdu w promieniu 50 km",
        "Współpraca z lokalnymi salami weselnymi",
        "Szybka dostępność terminów",
      ],
      nearbyAreas: [
        "Białystok",
        "Warszawa",
        "Łuków",
        "Mińsk Mazowiecki",
        "Sokołów Podlaski",
        "Węgrów",
        "Garwolin",
      ],
      heroImage: siedlceHeroimg,
      gridImages: [siedlceGridImg1, siedlceGridImg2],
    },
    bialystok: {
      name: "Białystok",
      nameLocative: "Białymstoku",
      nameGenitive: "Białegostoku",
      nameAdjective: "białostockie",
      region: "Podlaskie",
      postalCode: "15-001",
      metaDescription:
        "Fotograf ślubny w Białymstoku ✦ Reportaże ślubne, sesje plenerowe na Podlasiu. Naturalna fotografia pełna emocji. Zadzwoń: +48 660 872 121",
      aboutParagraphs: [
        "Podlasie to region, który pokochaliśmy za niezwykłe krajobrazy i wyjątkowy klimat. Regularnie realizujemy tu reportaże ślubne i sesje plenerowe, korzystając z tego, co ten region ma najpiękniejszego – Puszcza Knyszyńska, Dolina Narwi, pałace i dworki otoczone starymi alejami. To miejsca, które nadają zdjęciom niepowtarzalny charakter.",
        "Znamy specyfikę podlaskich wesel – ich tradycje, gościnność i emocje, które towarzyszą każdej uroczystości.",
        "Obsługujemy śluby i sesje w całym województwie podlaskim – Supraśl, Hajnówka, Augustów, Suwałki czy Łomża, to miejsca, do których z chęcią do Was dojedziemy.",
      ],
      serviceDescriptions: {
        wedding:
          "Reportaż ślubny od przygotowań, przez wzruszającą ceremonię, aż po szaloną zabawę. Podlaskie wesela mają niepowtarzalny klimat, a my potrafimy go uchwycić w każdym kadrze. Mieszkamy oraz studiujemy tutaj na codzień, więc znamy tutejsze okolice.",
        engagement:
          "Sesje narzeczeńskie w najpiękniejszych zakątkach Podlasia. Puszcza Knyszyńska, okolice Supraśla, Dolina Narwi – te miejsca tworzą magiczne tło dla Waszych zdjęć. To też okazja, żebyśmy się lepiej poznali przed ślubem.",
        postwedding:
          "Odpocznijcie po weselu i pozwólcie zaprosić się na luźną sesję poślubną w otoczeniu dzikiej podlaskiej przyrody. Zjawiskowe kadry z Rezerwatu Krzemionki, czy klimatycznej Kiszukówki to pamiątka na całe życie.",
      },
      faq: [
        {
          question: "Czy dojeżdżacie na śluby do Białegostoku?",
          answer:
            "Tak! Białystok to nasza druga baza — tutaj mieszkamy i studiujemy, więc działamy na miejscu jak lokalni fotografowie. Dojazd w promieniu 50 km od Białegostoku jest wliczony w cenę pakietu. Znamy podlaskie sale weselne, kościoły i najpiękniejsze lokalizacje na plener, dzięki czemu od razu skupiamy się na Was.",
        },
        {
          question: "Gdzie zrobić sesję narzeczeńską w okolicach Białegostoku?",
          answer:
            "Nasze ulubione miejsca to Puszcza Knyszyńska, okolice Supraśla z Monasterem, malownicze łąki nad Narwią i zabytkowe dworki. Każda z tych lokalizacji daje zupełnie inny klimat zdjęć — od dzikiej przyrody po eleganckie wnętrza. Chętnie pomożemy Wam dobrać scenerię, która najlepiej odda Wasz charakter jako pary.",
        },
        {
          question: "Jak wygląda współpraca z Wami?",
          answer:
            "Na początku spotykamy się — osobiście lub online — żeby poznać Waszą wizję i ustalić szczegóły dnia. Jeśli macie ochotę, przed ślubem widzimy się na sesji narzeczeńskiej, która świetnie przełamuje lody. W dniu ślubu towarzyszymy Wam od przygotowań do ok. godziny 1:00, a gotową galerię otrzymujecie w ciągu 3 miesięcy.",
        },
        {
          question: "Czy fotografujecie na Podlasiu poza Białymstokiem?",
          answer:
            "Oczywiście! Działamy w całym województwie podlaskim — Supraśl, Augustów, Suwałki, Łomża, Hajnówka i wiele innych lokalizacji. Podlasie to nasz drugi dom fotograficzny. Znamy unikalne miejsca w każdym z tych regionów, które idealnie nadają się na tło do sesji plenerowej lub reportażu ślubnego.",
        },
      ],
      localPlaces: [
        "Puszcza Knyszyńska",
        "Klimatyczna Kiszukówka",
        "Dolina Narwi",
        "Pałac Branickich",
        "Pałac Lubomirskich",
        "Park Planty",
      ],
      highlights: [
        "Regularne sesje w regionie podlaskim",
        "Znajomość malowniczych lokalizacji Podlasia",
        "Współpraca z podlaskimi salami weselnymi",
        "Dojazd wliczony w cenę pakietu",
      ],
      nearbyAreas: ["Siedlce", "Warszawa", "Supraśl", "Augustów", "Suwałki", "Łomża"],
      heroImage: bialystokHeroimg,
      heroPosition: "object-center",
      gridImages: [bialystokGridImg1, bialystokGridImg2],
    },
    warszawa: {
      name: "Warszawa",
      nameLocative: "Warszawie",
      nameGenitive: "Warszawy",
      nameAdjective: "warszawskie",
      region: "Mazowieckie",
      postalCode: "00-001",
      metaDescription:
        "Fotograf ślubny w Warszawie ✦ Elegancka fotografia ślubna w stolicy, sesje narzeczeńskie i ślubne. Duet fotografów. Zadzwoń: +48 660 872 121",
      aboutParagraphs: [
        "Warszawa oferuje nieograniczone możliwości dla fotografii ślubnej. Eleganckie pałace, nowoczesna architektura, urokliwe parki i nastrojowe kawiarnie – to daje nam wyjątkowe tła do tworzenia zdjęć, które zachwycą Was na lata.",
        "Jako duet fotografów działający głównie na Mazowszu, stolica jest dla nas naturalnym kierunkiem. Chętnie spotkamy się z wami także na sesji narzeczeńskiej lub poślubnej w Łazienkach Królewskich, na Starym Mieście, czy w nowoczesnych wnętrzach Wilanowa.",
      ],
      serviceDescriptions: {
        wedding:
          "Opowiadamy Wasz dzień w sposób naturalny, subtelny i pełen emocji. Od pierwszych przygotowań, przez wzruszającą ceremonię, aż po radość wspólnego świętowania — tworzymy kadry, do których będziecie wracać przez lata.",
        engagement:
          "Sesja narzeczeńska w klimatycznych zakątkach stolicy. Łazienki Królewskie, Stare Miasto, Park w Wilanowie, Muzeum Chopina – dobierzemy lokalizację, która podkreśli Wasz styl. To idealna okazja, żebyśmy poznali się przed ślubem.",
        postwedding:
          "Zjawiskowe sesje plenerowe niedługo po dniu Waszego ślubu. To szansa na odwiedzenie najbardziej spektakularnych miejsc na Mazowszu i w stolicy, bez stresu i pospiechu, w sam raz na romantyczne ujęcia w Waszych kreacjach.",
      },
      faq: [
        {
          question: "Czy dojeżdżacie na śluby do Warszawy i ile to kosztuje?",
          answer:
            "Tak! Stolica to jedno z głównych miast, w których działamy — Siedlce od Warszawy dzieli niecała godzina jazdy. Koszty dojazdu są wliczone w cenę pakietu. Uwielbiamy stolicę za różnorodność - każda para znajdzie tu miejsce na plener ślubny w swoim stylu.",
        },
        {
          question: "Gdzie najlepiej zrobić sesję narzeczeńską w Warszawie?",
          answer:
            "Warszawa oferuje mnóstwo pięknych lokalizacji na sesje! Nasze ulubione to Łazienki Królewskie (klasyczna elegancja), Stare Miasto (romantyczny klimat), Bulwary Wiślane (nowoczesny styl) i okolice Pałacu w Wilanowie. Dobieramy scenerię do Waszego charakteru i pory roku — chętnie pomożemy wybrać miejsce, które najlepiej odda Waszą historię.",
        },
        {
          question:
            "Czy fotografujecie śluby w podwarszawskich miejscowościach?",
          answer:
            "Oczywiście! Obsługujemy zarówno śluby w samej stolicy, jak i wesela w Piasecznie, Pruszkowie, Legionowie, Otwocku, Konstancinie-Jeziornie i wielu innych podwarszawskich miejscowościach. Podwarszawskie sale weselne oferują fantastyczne warunki — od kameralnych dworków po nowoczesne przestrzenie eventowe. Znamy wiele z nich i wiemy, jak najlepiej wykorzystać ich potencjał fotograficzny.",
        },
        {
          question: "Jak wygląda współpraca z fotografem spoza Warszawy?",
          answer:
            "Oczywiście! Obsługujemy zarówno śluby w samej stolicy, jak i wesela w Piasecznie, Pruszkowie, Legionowie, Otwocku, Konstancinie-Jeziornie i wielu innych podwarszawskich miejscowościach. Podwarszawskie sale weselne oferują fantastyczne warunki — od kameralnych dworków po nowoczesne przestrzenie eventowe.",
        },
      ],
      localPlaces: [
        "Łazienki Królewskie",
        "Stare Miasto",
        "Pałac w Wilanowie",
        "Pałac Rzeczypospolitej",
        "Muzeum Chopina",
      ],
      highlights: [
        "Sesje w prestiżowych lokalizacjach stolicy",
        "Znajomość warszawskich sal i kościołów",
        "Dojazd z Siedlec wliczony w cenę",
        "Dostępność w weekendy i długie weekendy",
      ],
      nearbyAreas: [
        "Siedlce",
        "Białystok",
        "Piaseczno",
        "Pruszków",
        "Legionowo",
        "Otwock",
        "Konstancin-Jeziorna",
      ],
      heroImage: warszawaHeroimg,
      heroPosition: "object-[center_80%]",
      gridImages: [warszawaGridImg1, warszawaGridImg2],
    },
  };

  return Object.entries(cities).map(([slug, cityData]) => ({
    params: { miasto: slug },
    props: { city: cityData, miasto: slug },
  }));
}

const { city, miasto } = Astro.props;

if (!city) {
  return Astro.redirect("/");
}

// Map city names to PSEO slugs for internal linking
const citySlugMap: Record<string, string> = {
  Siedlce: "siedlce",
  Białystok: "bialystok",
  Warszawa: "warszawa",
};

// Schema.org for Local Business
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Photographer",
  name: `Fiodorow Photography - Fotograf ${city.name}`,
  image: "https://fiodorowphotography.pl/og-image.jpg",
  description: city.metaDescription,
  "@id": "https://fiodorowphotography.pl/#photographer",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Siedlce",
    addressRegion: "Mazowieckie",
    postalCode: "08-110",
    addressCountry: "PL",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: {
      siedlce: 52.1676,
      bialystok: 53.1325,
      warszawa: 52.2297,
    }[miasto],
    longitude: {
      siedlce: 22.2903,
      bialystok: 23.1688,
      warszawa: 21.0122,
    }[miasto],
  },
  areaServed: {
    "@type": "City",
    name: city.name,
  },
  url: `https://fiodorowphotography.pl/fotograf-${miasto}`,
  telephone: "+48 660 872 121",
  priceRange: "$$",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday",
    ],
    opens: "09:00",
    closes: "20:00",
  },
};

// FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: city.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={`Fotograf ślubny ${city.name} | Fiodorow Photography`}
  description={city.metaDescription}
  breadcrumbs={[{ name: `Fotograf ${city.name}`, href: `/fotograf-${miasto}` }]}
>
  <Header />

  <!-- Hero -->
  <section
    class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden"
  >
    <div class="absolute inset-0">
      {
        typeof city.heroImage === "string" ? (
          <img
            src={city.heroImage}
            alt={`Fotograf ślubny w ${city.nameLocative} – sesja plenerowa`}
            class={`w-full h-full object-cover ${(city as any).heroPosition || "object-center"}`}
            loading="eager"
          />
        ) : (
          <Image
            src={city.heroImage}
            alt={`Fotograf ślubny w ${city.nameLocative} – sesja plenerowa`}
            class={`w-full h-full object-cover ${(city as any).heroPosition || "object-center"}`}
            loading="eager"
            quality={85}
            format="webp"
            widths={[600, 1200, 1920]}
            sizes="100vw"
          />
        )
      }
      <div class="hero-overlay absolute inset-0 bg-black/40"></div>
    </div>

    <div class="relative z-10 text-center text-white px-6 reveal reveal-up">
      <span class="text-xs tracking-[0.3em] uppercase opacity-80 mb-4 block">
        Województwo {city.region}
      </span>
      <h1
        class="font-serif text-4xl md:text-6xl font-light tracking-[0.15em] uppercase"
      >
        Fotograf ślubny<br /><span class="text-olive-light"
          >w {city.nameLocative}</span
        >
      </h1>
      <p
        class="mt-6 text-sm md:text-base text-white/80 max-w-xl mx-auto leading-relaxed"
      >
        Naturalny reportaż ślubny, sesje narzeczeńskie i ślubne. Duet fotografów
        z pasją do uwieczniania emocji.
      </p>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-20 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
      >
        <div class="reveal reveal-up">
          <span
            class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block"
            >O nas w {city.nameLocative}</span
          >
          <h2 class="section-title mb-6">
            Dlaczego warto wybrać nas w {city.nameLocative}?
          </h2>
          {
            city.aboutParagraphs.map((paragraph) => (
              <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-4">
                {paragraph}
              </p>
            ))
          }

          <!-- Removed Highlights per user request -->

          <a href="/kontakt" class="btn-primary mt-8 inline-block">
            Zapytaj o termin
          </a>
        </div>

        <div class="grid grid-cols-2 gap-4 reveal reveal-up reveal-d1">
          {
            typeof city.gridImages[0] === "string" ? (
              <img
                src={city.gridImages[0]}
                alt={`Sesja ślubna w ${city.nameLocative} – para młoda`}
                class="w-full aspect-[2/3] object-cover rounded-sm"
                loading="lazy"
              />
            ) : (
              <Image
                src={city.gridImages[0]}
                alt={`Sesja ślubna w ${city.nameLocative} – para młoda`}
                class="w-full aspect-[2/3] object-cover rounded-sm"
                loading="lazy"
                quality={80}
                format="webp"
                widths={[400, 800]}
                sizes="(max-width: 1024px) 50vw, 25vw"
              />
            )
          }
          {
            typeof city.gridImages[1] === "string" ? (
              <img
                src={city.gridImages[1]}
                alt={`Fotografia portretowa w ${city.nameLocative}`}
                class="w-full aspect-[2/3] object-cover mt-8 rounded-sm"
                loading="lazy"
              />
            ) : (
              <Image
                src={city.gridImages[1]}
                alt={`Fotografia portretowa w ${city.nameLocative}`}
                class="w-full aspect-[2/3] object-cover mt-8 rounded-sm"
                loading="lazy"
                quality={80}
                format="webp"
                widths={[400, 800]}
                sizes="(max-width: 1024px) 50vw, 25vw"
              />
