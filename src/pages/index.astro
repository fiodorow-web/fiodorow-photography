---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import Hero from '../components/Hero.astro';
import { getLatestPortfolio, urlFor, categoryLabels } from '../lib/sanity';
import { Image } from "astro:assets";
import aboutImg from "../assets/home/nasze2.jpg";
import sesjaPoSlubnaImg from "../assets/home/sesja-poslubna-plener-slubny.jpg";
import sesiaNarzeczenskaImg from "../assets/home/sesja-narzeczenska-plener.jpg";
import reportazSlubnyImg from "../assets/home/reportaz-slubny-para-mloda.jpg";

// Fetch latest 3 portfolio items from Sanity
let sanityItems: any[] = [];
try {
  sanityItems = await getLatestPortfolio(3);
} catch (e) {
  console.log('Sanity fetch failed, using fallback data');
}

// Fallback static data
const fallbackItems = [
  {
    image: "https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=1200&q=90",
    category: "reportaz-slubny",
    title: "Joanna & Darek",
    slug: { current: "joanna-darek" },
    date: "2024-06-08"
  },
  {
    image: "https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=1200&q=90",
    category: "sesja-narzeczenska",
    title: "Natalia & Michał",
    slug: { current: "natalia-michal" },
    date: "2024-05-15"
  },
  {
    image: "https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=1200&q=90",
    category: "reportaz-slubny",
    title: "Amelia & Damian",
    slug: { current: "amelia-damian" },
    date: "2024-07-22"
  }
];

// Use Sanity data if available
const portfolioItems = sanityItems.length > 0 ? sanityItems.map(item => ({
  image: item.coverImage ? urlFor(item.coverImage).width(1400).quality(85).auto('format').url() : fallbackItems[0].image,
  category: item.category,
  title: item.title,
  slug: item.slug,
  date: item.date
})) : fallbackItems;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Fiodorow Photography",
  "url": "https://fiodorowphotography.pl",
  "description": "Profesjonalna fotografia ślubna i portretowa — duet fotografów z Siedlec. Reportaże ślubne, sesje narzeczeńskie i plenerowe na Mazowszu, Podlasiu i Lubelszczyźnie.",
  "publisher": {
    "@type": "Photographer",
    "@id": "https://fiodorowphotography.pl/#photographer"
  }
};

const personSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Mateusz Fiodorow",
    "jobTitle": "Fotograf ślubny",
    "worksFor": { "@id": "https://fiodorowphotography.pl/#photographer" },
    "sameAs": [
      "https://www.instagram.com/fiodorow_photography",
      "https://www.facebook.com/fiodorowphotography"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Weronika Fiodorow",
    "jobTitle": "Fotograf ślubny",
    "worksFor": { "@id": "https://fiodorowphotography.pl/#photographer" },
    "sameAs": [
      "https://www.instagram.com/fiodorow_photography",
      "https://www.facebook.com/fiodorowphotography"
    ]
  }
];
---

<BaseLayout
  title="Fiodorow Photography | Fotograf Siedlce, Białystok, Warszawa"
  description="Profesjonalna fotografia ślubna i portretowa – Fiodorow Photography. Reportaże ślubne, sesje narzeczeńskie i plenerowe. Siedlce, Białystok, Warszawa."
  breadcrumbs={[]}
>
  <Header currentPath="/" />

  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {personSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <h1 class="sr-only">Fiodorow Photography — Fotograf Ślubny Siedlce, Białystok, Warszawa</h1>

  <!-- Hero Section -->
  <Hero />
  
  <!-- Portfolio Section - Asymmetric Grid with Hover Effects -->
  <section class="py-20 md:py-32 bg-cream">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      
      <!-- Asymmetric Grid Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16">
        
        <!-- Left Column: Title + Single Large Item (Centered) -->
        <div class="flex flex-col relative lg:h-full lg:justify-center">
          <!-- Moved Title and Subtitle Here -->
          <div class="text-left mb-12 lg:mb-0 lg:absolute lg:top-0 lg:left-0 lg:w-full z-20 reveal reveal-up">
            <h2 class="font-serif text-2xl md:text-3xl tracking-[0.2em] uppercase text-charcoal mb-4">
              Portfolio
            </h2>
            <p class="text-charcoal-light text-base md:text-lg max-w-sm italic font-serif">
            Każda para to inna historia.<br />
            Zajrzyjcie do środka i zobaczcie, jak je opowiadamy.
            </p>
          </div>

          <!-- Left Item (Centered in remaining height) -->
          {portfolioItems[0] && (
            <a 
              href={`/portfolio/${portfolioItems[0].slug.current}`} 
              class="reveal reveal-slide-left-heavy group block w-full relative overflow-hidden shadow-xl"
              
            >
              <div class="relative w-full aspect-[3/4] overflow-hidden">
                <img 
                  src={portfolioItems[0].image}
                  alt={`${categoryLabels[portfolioItems[0].category] || portfolioItems[0].category} — ${portfolioItems[0].title}, fotograf ślubny Siedlce`}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading="eager"
                />
                
                <!-- Always-visible bottom gradient -->
                <div class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none"></div>
                
                <!-- Desktop hover overlay -->
                <div class="absolute inset-0 bg-black/20 opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                
                <!-- Desktop centered plus icon -->
                <div class="absolute inset-0 hidden lg:flex items-center justify-center pointer-events-none">
                    <span class="text-white text-5xl font-light opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all duration-500">+</span>
                </div>

                <!-- Bottom Text (always visible) -->
                <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-left z-10">
                    <span class="text-[0.6rem] md:text-[0.65rem] tracking-[0.25em] uppercase text-white/80 block mb-1.5">
                    {categoryLabels[portfolioItems[0].category] || portfolioItems[0].category}
                    </span>
                    <h3 class="font-serif text-xl md:text-2xl lg:text-3xl tracking-[0.1em] uppercase text-white">
                    {portfolioItems[0].title}
                    </h3>
                    <!-- Desktop: "Zobacz sesję" label on hover -->
                    <span class="hidden lg:inline-block mt-3 text-[0.65rem] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/90 border-b border-white/0 group-hover:border-white/60 pb-0.5 transition-all duration-500 delay-100">Zobacz sesję →</span>
                    <!-- Mobile: always-visible hint -->
                    <span class="lg:hidden block mt-2 text-[0.55rem] tracking-[0.15em] uppercase text-white/60">Kliknij aby zobaczyć →</span>
                </div>
              </div>
            </a>
          )}
        </div>
        
        <!-- Right Column: Two Stacked Items -->
        <div class="flex flex-col gap-12 md:gap-16">
          {portfolioItems.slice(1, 3).map((item, index) => (
            <a 
              href={`/portfolio/${item.slug.current}`} 
              class={`reveal reveal-slide-right-heavy ${index === 0 ? 'reveal-d1' : 'reveal-d2'} group block relative overflow-hidden shadow-lg`}
              
            >
              <div class="relative w-full aspect-[3/4] overflow-hidden">
                <img 
                  src={item.image}
                  alt={`${categoryLabels[item.category] || item.category} — ${item.title}, fotograf ślubny Mazowsze`}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading="lazy"
                />

                <!-- Always-visible bottom gradient -->
                <div class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none"></div>
                
                <!-- Desktop hover overlay -->
                <div class="absolute inset-0 bg-black/20 opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                
                <!-- Desktop centered plus icon -->
                <div class="absolute inset-0 hidden lg:flex items-center justify-center pointer-events-none">
                    <span class="text-white text-4xl font-light opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all duration-500">+</span>
                </div>

                <!-- Bottom Text (always visible) -->
                <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-left z-10">
                    <span class="text-[0.6rem] md:text-[0.65rem] tracking-[0.25em] uppercase text-white/80 block mb-1.5">
                    {categoryLabels[item.category] || item.category}
                    </span>
                    <h3 class="font-serif text-lg md:text-xl lg:text-2xl tracking-[0.1em] uppercase text-white">
                    {item.title}
                    </h3>
                    <!-- Desktop: "Zobacz sesję" label on hover -->
                    <span class="hidden lg:inline-block mt-3 text-[0.65rem] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/90 border-b border-white/0 group-hover:border-white/60 pb-0.5 transition-all duration-500 delay-100">Zobacz sesję →</span>
                    <!-- Mobile: always-visible hint -->
                    <span class="lg:hidden block mt-2 text-[0.55rem] tracking-[0.15em] uppercase text-white/60">Kliknij aby zobaczyć →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
      
      <!-- CTA Button -->
      <div class="text-center mt-12 reveal reveal-up reveal-d3">
        <a href="/portfolio" class="btn-primary">
          Zobacz wszystkie
        </a>
      </div>
    </div>
  </section>
  
  <!-- Duo Section (Replaces About Teaser) -->
  <section class="py-20 md:py-32 bg-white overflow-hidden">
    <div class="max-w-[1600px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        
        <!-- Image Side with Badge -->
        <div class="relative group reveal reveal-left order-2 md:order-1 lg:col-span-7">
          <!-- Decorative Elements -->
          <div class="absolute top-8 -right-8 w-full h-full border border-charcoal/10 rounded-sm -z-10 transition-transform duration-700 group-hover:translate-x-2 group-hover:-translate-y-2 hidden md:block"></div>
          <div class="absolute -bottom-12 -left-12 w-3/4 h-3/4 bg-olive/10 rounded-full blur-3xl -z-20 mix-blend-multiply"></div>
          
          <div class="relative z-10">
            <Image 
              src={aboutImg} 
              alt="Mateusz i Weronika - Duet Fotografów" 
              class="w-full h-auto aspect-[3/2] object-cover object-center rounded-sm shadow-2xl transition-transform duration-1000 group-hover:scale-[1.02]" 
              widths={[480, 800, 1500]}
              sizes="(max-width: 1024px) 100vw, 58vw"
              quality={75}
              format="webp"
            />
          </div>
        </div>
        
        <!-- Text Side -->
        <div class="order-1 md:order-2 reveal reveal-right lg:col-span-5">
          <span class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Dlaczego My?</span>
          <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-charcoal mb-8 leading-tight">
            Duet w życiu <br/> <i class="font-light italic text-olive font-serif">i w fotografii</i>
          </h2>
          <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-6">
            Łączy nas miłość do ludzi, emocji i nieustannego działania. Fotografia to dla nas nie tylko praca, ale przede wszystkim szansa na poznanie Was i Waszych historii.
          </p>
          <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-6">
            Specjalizujemy się w reportażach ślubnych, sesjach plenerowych i lifestyle, ale z radością podejmujemy się też innych fotograficznych wyzwań, które nam powierzacie. Działamy głównie na terenie Mazowsza, Podlasia i Lubelszczyzny – choć z chęcią dojedziemy także dalej.
          </p>
          <p class="text-charcoal-light text-sm md:text-base leading-relaxed mb-10">
            Fiodorow Photography to nasza wspólna droga i pasja do uwieczniania prawdziwych emocji. Od ponad 6 lat, z każdym kolejnym zrealizowanym reportażem ślubnym wkładamy całe serce w to, aby opowiedzieć Waszą historię. Jako zgrany duet fotografów, dajemy Wam podwójną uważność — na miejscu jesteśmy zawsze we dwoje.
          </p>
          <a href="/o-nas" class="btn-primary">
            Poznaj naszą historię
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Jak Pracujemy Section -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal reveal-up">
        <span class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Proces</span>
        <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-4">
          Jak <i class="font-light italic text-olive font-serif">pracujemy</i>
        </h2>
        <p class="text-charcoal-light text-sm max-w-lg mx-auto">
          Od pierwszego kontaktu do odbioru galerii.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
        <!-- Step 1 -->
        <div class="text-center reveal reveal-up">
          <div class="w-14 h-14 mx-auto mb-6 rounded-full border border-olive/30 flex items-center justify-center">
            <span class="font-serif text-xl text-olive">1</span>
          </div>
          <h3 class="font-serif text-lg tracking-[0.1em] uppercase text-charcoal mb-3">Kontakt</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Zadzwońcie lub napiszcie — opowiedzcie o swoich planach. Chętnie odpowiemy na pytania i doradzimy, bez żadnych zobowiązań.
          </p>
        </div>
        
        <!-- Step 2 -->
        <div class="text-center reveal reveal-up reveal-d1">
          <div class="w-14 h-14 mx-auto mb-6 rounded-full border border-olive/30 flex items-center justify-center">
            <span class="font-serif text-xl text-olive">2</span>
          </div>
          <h3 class="font-serif text-lg tracking-[0.1em] uppercase text-charcoal mb-3">Spotkanie</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Spotykamy się, żeby się poznać i porozmawiać o Waszym dniu. Ustalamy harmonogram, lokalizacje i wszystko, co ważne.
          </p>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center reveal reveal-up reveal-d2">
          <div class="w-14 h-14 mx-auto mb-6 rounded-full border border-olive/30 flex items-center justify-center">
            <span class="font-serif text-xl text-olive">3</span>
          </div>
          <h3 class="font-serif text-lg tracking-[0.1em] uppercase text-charcoal mb-3">Wasz dzień</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Fotografujemy naturalnie, bez sztucznych póz. Jesteśmy dyskretni, ale zawsze tam, gdzie dzieją się emocje.
          </p>
        </div>
        
        <!-- Step 4 -->
        <div class="text-center reveal reveal-up reveal-d3">
          <div class="w-14 h-14 mx-auto mb-6 rounded-full border border-olive/30 flex items-center justify-center">
            <span class="font-serif text-xl text-olive">4</span>
          </div>
          <h3 class="font-serif text-lg tracking-[0.1em] uppercase text-charcoal mb-3">Odbiór zdjęć</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Starannie obrabiamy każde zdjęcie. W ciągu 3 miesięcy otrzymujecie kompletną galerię online — gotową do pobrania.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Usługi Section -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <div class="text-center mb-16 reveal reveal-up">
        <span class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Oferta</span>
        <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-4">
          Co <i class="font-light italic text-olive font-serif">oferujemy</i>
        </h2>
        <p class="text-charcoal-light text-sm max-w-lg mx-auto">
          Do każdej pary podchodzimy indywidualnie — z pełną otwartością na Wasze pomysły. Porozmawiajcie z nami o szczegółach.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        <!-- Sesja Narzeczeńska -->
        <a href="/portfolio" class="group reveal reveal-up">
          <div class="relative aspect-[4/5] overflow-hidden rounded-sm mb-6">
            <Image
              src={sesiaNarzeczenskaImg}
              alt="Sesja narzeczeńska w plenerze — para zakochanych, fotograf ślubny Siedlce"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              widths={[400, 800]}
              sizes="(max-width: 768px) 100vw, 33vw"
              quality={85}
              format="webp"
            />
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/60 to-transparent"></div>
          </div>
          <h3 class="font-serif text-xl tracking-[0.1em] uppercase text-charcoal mb-2 group-hover:text-olive transition-colors">Sesja Narzeczeńska</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            To idealna okazja, żebyśmy poznali się przed ślubem. Przełamiemy pierwsze lody przed obiektywem, tworząc dla Was piękną, klimatyczną pamiątkę. Otrzymujecie średnio około 40 profesjonalnie obrobionych zdjęć.
          </p>
        </a>

        <!-- Reportaż Ślubny -->
        <a href="/portfolio" class="group reveal reveal-up reveal-d1">
          <div class="relative aspect-[4/5] overflow-hidden rounded-sm mb-6">
            <Image
              src={reportazSlubnyImg}
              alt="Reportaż ślubny — emocjonalne momenty ceremonii, fotograf ślubny Mazowsze"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              widths={[400, 800]}
              sizes="(max-width: 768px) 100vw, 33vw"
              quality={85}
              format="webp"
            />
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/60 to-transparent"></div>
          </div>
          <h3 class="font-serif text-xl tracking-[0.1em] uppercase text-charcoal mb-2 group-hover:text-olive transition-colors">Reportaż Ślubny</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Kompletny reportaż Waszego dnia — około 700 starannie obrobionych zdjęć. Działamy dyskretnie, łapiąc ulotne chwile i spojrzenia, których Wy w natłoku emocji możecie nawet nie zauważyć. Dwa aparaty, dwa spojrzenia — towarzyszymy Wam od przygotowań do zabawy weselnej.
          </p>
        </a>
        
        <!-- Sesja Poślubna -->
        <a href="/portfolio" class="group reveal reveal-up reveal-d2">
          <div class="relative aspect-[4/5] overflow-hidden rounded-sm mb-6">
            <Image
              src={sesjaPoSlubnaImg}
              alt="Sesja poślubna — plener ślubny pary młodej w plenerze, fotograf Podlasie"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              widths={[400, 800]}
              sizes="(max-width: 768px) 100vw, 33vw"
              quality={85}
              format="webp"
            />
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/60 to-transparent"></div>
          </div>
          <h3 class="font-serif text-xl tracking-[0.1em] uppercase text-charcoal mb-2 group-hover:text-olive transition-colors">Sesja Poślubna</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Plener po ślubie — bez pośpiechu, w Waszej wymarzonej lokalizacji. To czas na zdjęcia jak z okładki, tylko we dwoje. Zazwyczaj wykonujemy go niedługo po dniu ślubu we wspólnie wybranym terminie.
          </p>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Testimonials Section -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-5xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12 reveal reveal-up">
        <span class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block">Opinie</span>
        <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-4">
          Co mówią <i class="font-light italic text-olive font-serif">Pary</i>
        </h2>
        <p class="text-charcoal-light text-sm max-w-lg mx-auto">
          Poznajcie opinie par, które nam zaufały. Wasze słowa są dla nas najważniejsze!
        </p>
      </div>
      
      <!-- Static testimonials (hidden visually, accessible to AI crawlers and screen readers) -->
      <div class="sr-only">
        <blockquote>
          <p>„Jesteśmy bardzo zadowoleni ze współpracy z Weroniką i Mateuszem od początku do końca. Tworzą tak ciepłą i swobodną atmosferę, że można zachowywać się zupełnie naturalnie. Zdjęcia wyszły bardzo naturalne, pełne emocji i cudownie oddają atmosferę dnia."</p>
          <footer>— Maria i Piotr</footer>
        </blockquote>
        <blockquote>
          <p>„Przepiękne zdjęcia, świetna współpraca i pełen profesjonalizm. Weronika i Mateusz uchwycili magię naszego wesela w najpiękniejszy możliwy sposób. Zdecydowanie polecamy!"</p>
          <footer>— Dominika i Szymon</footer>
        </blockquote>
        <blockquote>
          <p>„Całym sercem polecamy Weronikę i Mateusza, zdecydowanie najlepszy duet fotografów. Od pierwszego spotkania wiedzieliśmy, że to będzie strzał w dziesiątkę — zdjęcia wyszły po prostu magicznie."</p>
          <footer>— Amelia i Damian</footer>
        </blockquote>
      </div>

      <!-- Elfsight Google Reviews Widget (lazy-loaded) -->
      <div class="elfsight-reviews-container reveal reveal-up reveal-d2" id="elfsight-container">
        <div class="elfsight-app-11d18e3f-c547-4cab-adfc-247a1b196ee8" data-elfsight-app-lazy></div>
      </div>
      <script>
        const elfsightContainer = document.getElementById('elfsight-container');
        if (elfsightContainer) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const script = document.createElement('script');
                script.src = 'https://elfsightcdn.com/platform.js';
                script.async = true;
                document.head.appendChild(script);
                observer.disconnect();
              }
            });
          }, { rootMargin: '200px' });
          observer.observe(elfsightContainer);
        }
      </script>
    </div>
