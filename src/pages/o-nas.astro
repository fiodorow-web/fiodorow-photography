---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import { Image } from "astro:assets";
import aboutImg from "../assets/about/about.jpg";

const studioImage =
  "https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=800&q=80";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Jak wcześnie rezerwować termin?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Najlepiej 6-12 miesięcy przed ślubem, szczególnie w sezonie (maj-wrzesień). Im wcześniej, tym większa pewność, że będziemy dostępni w Waszym terminie!",
      },
    },
    {
      "@type": "Question",
      name: "Czy dojeżdżacie poza Mazowsze?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tak! Działamy głównie na Mazowszu, Podlasiu i Lubelszczyźnie, ale chętnie dojedziemy też dalej. Skontaktujcie się z nami, a ustalimy szczegóły.",
      },
    },
    {
      "@type": "Question",
      name: "Ile zdjęć otrzymamy i kiedy?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Przeciętnie otrzymacie 400-600 starannie wyselekcjonowanych i obrobionych zdjęć z reportażu. Galeria online będzie gotowa w ciągu 4-6 tygodni od ślubu.",
      },
    },
    {
      "@type": "Question",
      name: "Czy oferujecie sesję narzeczeńską?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Tak! Sesja narzeczeńska to świetna okazja, żebyśmy się poznali przed wielkim dniem. Często wchodzi w skład pakietu, ale można ją też zamówić osobno.",
      },
    },
    {
      "@type": "Question",
      name: 'Jak wygląda praca "w duecie"?',
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pracujemy razem jako zespół — dwa spojrzenia, dwie perspektywy. Dzięki temu nie umknie żaden ważny moment, a Wy otrzymacie bogatszą historię Waszego dnia.",
      },
    },
  ],
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://fiodorowphotography.pl",
  name: "Fiodorow Photography",
  description:
    "Duet fotografów ślubnych z Siedlec. Naturalny reportaż ślubny, sesje narzeczeńskie i poślubne na Mazowszu, Podlasiu i Lubelszczyźnie.",
  url: "https://fiodorowphotography.pl",
  telephone: "+48660872121",
  email: "fiodorowphotography@gmail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Siedlce",
    postalCode: "08-110",
    addressRegion: "Mazowieckie",
    addressCountry: "PL",
  },
  areaServed: [
    { "@type": "State", name: "Mazowieckie" },
    { "@type": "State", name: "Podlaskie" },
    { "@type": "State", name: "Lubelskie" },
  ],
  priceRange: "$$",
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday",
    ],
    opens: "08:00",
    closes: "20:00",
  },
};
---

<BaseLayout
  title="O nas — Fotograf Ślubny Siedlce | Fiodorow Photography"
  description="Mateusz i Weronika — duet fotografów ślubnych z Siedlec. Naturalny reportaż ślubny, sesje narzeczeńskie i poślubne na Mazowszu, Podlasiu i Lubelszczyźnie."
  breadcrumbs={[{ name: "O nas", href: "/o-nas" }]}
>
  <Header currentPath="/o-nas" />

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <!-- Hero Section - Contained & Elegant -->
  <section class="pt-32 pb-20 md:pt-40 md:pb-32 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center"
      >
        <!-- Content Side (Left) -->
        <div class="order-2 lg:order-1 reveal reveal-up">
          <h1
            class="font-serif text-4xl md:text-5xl tracking-[0.1em] uppercase mb-8 text-charcoal"
          >
            Poznajmy <i class="font-light italic text-olive">się</i>!
          </h1>
          <div
            class="space-y-6 text-charcoal-light text-base leading-relaxed font-light"
          >
            <p class="font-medium text-lg text-charcoal">
              Cześć! Tu Mateusz i Weronika – duet w życiu i w fotografii.
            </p>
            <p>
              Jesteśmy teamem, który świetnie się uzupełnia. Weronika zajmuje
              się selekcją zdjęć, planowaniem sesji oraz tworzeniem albumów.
              Mateusz uwielbia techniczne aspekty fotografii, dlatego sprzęt i
              obróbka zdjęć to jego świat.
            </p>
            <p>
              Doskonale rozumiemy, jak stresujące może być stanie po drugiej
              stronie obiektywu. Dlatego dbamy o to, aby każdy etap współpracy
              był dla Was jak najbardziej komfortowy. Zawsze służymy dobrą radą
              i wsparciem.
            </p>
            <p>
              Na co dzień jesteśmy studentami – Mateusz informatyki, a Weronika
              fizjoterapii. Jesteśmy z Siedlec, ale mieszkamy w Białymstoku.
              Nasz główny obszar działania to województwa mazowieckie, podlaskie
              i lubelskie – ale chętnie dojedziemy też dalej!
            </p>
            <p>
              Jesteśmy tu po to, by uchwycić Wasze najpiękniejsze chwile, do
              których będziecie wracać z uśmiechem na twarzy.
            </p>
          </div>
          <a href="/portfolio" class="btn-primary mt-8 inline-block">
            Zobacz nasze prace
          </a>
        </div>

        <!-- Image Side (Right) -->
        <div
          class="relative order-1 lg:order-2 mb-10 lg:mb-0 reveal reveal-right"
        >
          <div class="relative z-10">
            <Image
              src={aboutImg}
              alt="Mateusz i Weronika — fotografowie ślubni Fiodorow Photography, Siedlce"
              class="w-full h-auto aspect-[4/5] object-cover rounded-sm shadow-xl"
              loading="eager"
              width={800}
              quality={95}
            />
          </div>
          <!-- Decorative Frame -->
          <div
            class="absolute top-6 -right-6 w-full h-full border border-charcoal/20 -z-0 rounded-sm hidden md:block"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-20 md:py-32 section-cream">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <h2 class="section-title text-center mb-16 reveal reveal-up">
        Nasze <i class="font-light italic text-olive">podejście</i>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 reveal-stagger">
        <!-- Value 1 -->
        <div class="text-center reveal reveal-up">
          <div
            class="w-16 h-16 mx-auto mb-6 flex items-center justify-center border border-charcoal/20"
          >
            <svg
              class="w-8 h-8 text-olive"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1"
                d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"
              ></path>
            </svg>
          </div>
          <h3 class="font-serif text-lg tracking-[0.15em] uppercase mb-4">
            Duet<br />Fotografów
          </h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Pracujemy we dwoje. Oznacza to dwie różne perspektywy, więcej
            chwytanych uśmiechów i pewność, że żaden ważny moment nam nie
            umknie. Jako że sami jesteśmy parą, wiemy dokładnie, jakie emocje
            Wam towarzyszą.
          </p>
        </div>

        <!-- Value 2 -->
        <div class="text-center reveal reveal-up">
          <div
            class="w-16 h-16 mx-auto mb-6 flex items-center justify-center border border-charcoal/20"
          >
            <svg
              class="w-8 h-8 text-olive"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1"
                d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1"
                d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            </svg>
          </div>
          <h3 class="font-serif text-lg tracking-[0.15em] uppercase mb-4">
            Świeże<br />spojrzenie
          </h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Jesteśmy młodzi, wnosimy nowoczesne, dynamiczne spojrzenie. Szukamy
            naturalnych kadrów pełnych luzu i niepozowanych momentów.
          </p>
        </div>

        <!-- Value 3 -->
        <div class="text-center reveal reveal-up">
          <div
            class="w-16 h-16 mx-auto mb-6 flex items-center justify-center border border-charcoal/20"
          >
            <svg
              class="w-8 h-8 text-olive"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1"
                d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
              ></path>
            </svg>
          </div>
          <h3 class="font-serif text-lg tracking-[0.15em] uppercase mb-4">
            Kompleksowa obsługa
          </h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Nie kończymy na oddaniu Wam galerii online. Ręcznie projektujemy
            ponadczasowe, eleganckie fotoalbumy ślubne, a jeśli chcecie
            rozkręcić imprezę — wpadamy na salę z naszą fotobudką!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Working Area Section -->
  <section class="py-20 md:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
      >
        <!-- Image -->
        <div class="order-2 lg:order-1 reveal reveal-left">
          <img
            src={studioImage}
            alt="Obszar działania - Siedlce, Białystok, Warszawa"
            class="w-full h-[500px] object-cover"
            loading="lazy"
          />
        </div>

        <!-- Content -->
        <div class="order-1 lg:order-2 reveal reveal-right">
          <h2 class="section-title mb-8">
            Gdzie <i class="font-light italic text-olive">działamy</i>
          </h2>
          <div
            class="space-y-6 text-charcoal-light text-sm md:text-base leading-relaxed"
          >
            <p>
              Nasza główna baza to Siedlce. Działamy głównie na terenie
              Mazowsza, Podlasia i Lubelszczyzny – choć z chęcią dojedziemy
              także dalej. Uwielbiamy nowe miejsca, podróże i pracę na terenie
              całego kraju.
            </p>
            <p>
              Naszą ogromną pasją jest odkrywanie świata, dlatego z radością
              wykonamy dla Was również sesję zagraniczną. Marzy Wam się plener
              we włoskich uliczkach, na dzikiej plaży, a może na tle norweskich
              fiordów? Spakujemy sprzęt, zabierzemy naszą dobrą energię i z
              przyjemnością z Wami polecimy!
            </p>
          </div>
          <a href="/kontakt" class="btn-primary mt-8 inline-block">
            Zapytaj o termin
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 md:py-28 bg-cream">
    <div class="max-w-3xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12 reveal reveal-up">
        <span
          class="text-olive text-xs font-bold tracking-[0.2em] uppercase mb-4 block"
          >FAQ</span
        >
        <h2 class="font-serif text-3xl md:text-4xl text-charcoal mb-4">
          Najczęściej zadawane <i
            class="font-light italic text-olive font-serif">pytania</i
          >
        </h2>
      </div>

      <div class="space-y-4 reveal-stagger" id="faq-accordion">
        <!-- Question 1 -->
        <div
          class="faq-item border border-charcoal/10 rounded-sm overflow-hidden bg-white reveal reveal-up"
        >
          <button
            class="faq-trigger w-full flex items-center justify-between p-6 text-left bg-cream/30 hover:bg-cream transition-colors group"
          >
            <span
              class="font-serif text-lg text-charcoal group-hover:text-olive transition-colors"
              >Jak wcześnie rezerwować termin?</span
            >
            <svg
              class="faq-icon w-5 h-5 text-olive transition-transform duration-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="faq-content grid grid-rows-[0fr] transition-all duration-500 ease-out"
          >
            <div class="overflow-hidden">
              <div class="p-6 pt-0">
                <p class="text-charcoal-light text-sm leading-relaxed">
                  Najlepiej 6-12 miesięcy przed ślubem, szczególnie w sezonie
                  (maj-wrzesień). Im wcześniej, tym większa pewność, że będziemy
                  dostępni w Waszym terminie!
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Question 2 -->
        <div
          class="faq-item border border-charcoal/10 rounded-sm overflow-hidden bg-white reveal reveal-up"
        >
          <button
            class="faq-trigger w-full flex items-center justify-between p-6 text-left bg-cream/30 hover:bg-cream transition-colors group"
          >
            <span
              class="font-serif text-lg text-charcoal group-hover:text-olive transition-colors"
              >Czy dojeżdżacie poza Mazowsze?</span
            >
            <svg
              class="faq-icon w-5 h-5 text-olive transition-transform duration-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="faq-content grid grid-rows-[0fr] transition-all duration-500 ease-out"
          >
            <div class="overflow-hidden">
              <div class="p-6 pt-0">
                <p class="text-charcoal-light text-sm leading-relaxed">
                  Tak! Działamy głównie na Mazowszu, Podlasiu i Lubelszczyźnie,
                  ale chętnie dojedziemy też dalej. Skontaktujcie się z nami, a
                  ustalimy szczegóły.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Question 3 -->
        <div
          class="faq-item border border-charcoal/10 rounded-sm overflow-hidden bg-white reveal reveal-up"
        >
          <button
            class="faq-trigger w-full flex items-center justify-between p-6 text-left bg-cream/30 hover:bg-cream transition-colors group"
          >
            <span
              class="font-serif text-lg text-charcoal group-hover:text-olive transition-colors"
              >Ile zdjęć otrzymamy i kiedy?</span
            >
            <svg
              class="faq-icon w-5 h-5 text-olive transition-transform duration-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="faq-content grid grid-rows-[0fr] transition-all duration-500 ease-out"
          >
            <div class="overflow-hidden">
              <div class="p-6 pt-0">
                <p class="text-charcoal-light text-sm leading-relaxed">
                  Przeciętnie otrzymacie 300-700 (zależnie od pakietu) starannie
                  wyselekcjonowanych i obrobionych zdjęć z reportażu. Galeria
                  online będzie gotowa do 3 miesięcy od dnia ślubu.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Question 4 -->
        <div
          class="faq-item border border-charcoal/10 rounded-sm overflow-hidden bg-white reveal reveal-up"
        >
          <button
            class="faq-trigger w-full flex items-center justify-between p-6 text-left bg-cream/30 hover:bg-cream transition-colors group"
          >
            <span
              class="font-serif text-lg text-charcoal group-hover:text-olive transition-colors"
              >Czy oferujecie sesję narzeczeńską?</span
            >
            <svg
              class="faq-icon w-5 h-5 text-olive transition-transform duration-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="faq-content grid grid-rows-[0fr] transition-all duration-500 ease-out"
          >
            <div class="overflow-hidden">
              <div class="p-6 pt-0">
                <p class="text-charcoal-light text-sm leading-relaxed">
                  Tak! Sesja narzeczeńska to świetna okazja, żebyśmy się poznali
                  przed wielkim dniem. Często wchodzi w skład pakietu, ale można
                  ją też zamówić osobno.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Question 5 -->
        <div
          class="faq-item border border-charcoal/10 rounded-sm overflow-hidden bg-white reveal reveal-up"
        >
          <button
            class="faq-trigger w-full flex items-center justify-between p-6 text-left bg-cream/30 hover:bg-cream transition-colors group"
          >
            <span
              class="font-serif text-lg text-charcoal group-hover:text-olive transition-colors"
              >Jak wygląda praca "w duecie"?</span
            >
            <svg
              class="faq-icon w-5 h-5 text-olive transition-transform duration-500"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            class="faq-content grid grid-rows-[0fr] transition-all duration-500 ease-out"
          >
            <div class="overflow-hidden">
              <div class="p-6 pt-0">
                <p class="text-charcoal-light text-sm leading-relaxed">
                  Pracujemy razem jako zespół — dwa spojrzenia, dwie
                  perspektywy. Dzięki temu nie umknie nam żaden ważny moment, a
                  Wy otrzymacie bogatszą historię Waszego dnia.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull-quote -->
  <section class="py-16 md:py-20 section-olive">
    <div
      class="max-w-4xl mx-auto px-6 md:px-12 text-center text-white reveal reveal-fade"
    >
      <svg
        class="w-8 h-8 mx-auto mb-6 text-white/40"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
        ></path>
      </svg>
      <p
        class="font-serif text-lg md:text-xl italic leading-relaxed mb-6 text-white/90"
      >
        "Całym sercem polecamy Weronikę i Mateusza, zdecydowanie najlepszy duet
        fotografów. Kontakt od początku do końca oceniamy bardzo pozytywnie, od
        pierwszego spotkania wiedzieliśmy, że to będzie strzał w 10, zdjęcia
        wyszły po prostu magicznie, serdecznie polecamy."
      </p>
      <span class="text-[0.7rem] tracking-[0.2em] uppercase text-white/60"
        >— Amelia & Damian</span
      >
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 md:py-24 bg-cream-dark">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="section-title mb-6 reveal reveal-up">
        Planujecie <i class="font-light italic text-olive font-serif">ślub</i>?
      </h2>
      <p
        class="text-charcoal-light text-sm md:text-base leading-relaxed mb-10 max-w-xl mx-auto reveal reveal-up reveal-d1"
      >
