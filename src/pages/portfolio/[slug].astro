---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getPortfolioItems, urlFor, categoryLabels } from "../../lib/sanity";

// Fetch from Sanity for static path generation
export async function getStaticPaths() {
  // Fallback static data
  const fallbackData: Record<string, any> = {
    "joanna-darek": {
      title: "Joanna & Darek",
      date: "8 czerwca 2024",
      category: "reportaz-slubny",
      venue: {
        venueName: "Siedlce",
        venueUrl: "https://maps.google.com/?q=Siedlce",
      },
      images: [
        { src: "https://images.unsplash.com/photo-1519741497674-611481863552?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1519741497674-611481863552?w=400&q=80 400w, https://images.unsplash.com/photo-1519741497674-611481863552?w=800&q=85 800w, https://images.unsplash.com/photo-1519741497674-611481863552?w=1400&q=90 1400w" },
        { src: "https://images.unsplash.com/photo-1606800052052-a08af7148866?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1606800052052-a08af7148866?w=400&q=80 400w, https://images.unsplash.com/photo-1606800052052-a08af7148866?w=800&q=85 800w, https://images.unsplash.com/photo-1606800052052-a08af7148866?w=1400&q=90 1400w" },
        { src: "https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=400&q=80 400w, https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=800&q=85 800w, https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=1400&q=90 1400w" },
      ],
    },
    "natalia-michal": {
      title: "Natalia & Michał",
      date: "15 maja 2024",
      category: "sesja-narzeczenska",
      venue: {
        venueName: "Białystok",
        venueUrl: "https://maps.google.com/?q=Bialystok",
      },
      images: [
        { src: "https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=400&q=80 400w, https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=800&q=85 800w, https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=1400&q=90 1400w" },
        { src: "https://images.unsplash.com/photo-1529634806980-85c3dd6d34ac?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1529634806980-85c3dd6d34ac?w=400&q=80 400w, https://images.unsplash.com/photo-1529634806980-85c3dd6d34ac?w=800&q=85 800w, https://images.unsplash.com/photo-1529634806980-85c3dd6d34ac?w=1400&q=90 1400w" },
      ],
    },
    "amelia-damian": {
      title: "Amelia & Damian",
      date: "22 lipca 2024",
      category: "reportaz-slubny",
      venue: {
        venueName: "Warszawa",
        venueUrl: "https://maps.google.com/?q=Warszawa",
      },
      images: [
        { src: "https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=400&q=80 400w, https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=800&q=85 800w, https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=1400&q=90 1400w" },
        { src: "https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=1400&q=90", srcset: "https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=400&q=80 400w, https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=800&q=85 800w, https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=1400&q=90 1400w" },
      ],
    },
  };

  // Try to fetch from Sanity
  let sanityItems: any[] = [];
  try {
    sanityItems = await getPortfolioItems();
  } catch (e) {
    console.log("Sanity fetch failed in getStaticPaths, using fallback");
  }

  // Build paths from Sanity data
  const sanityPaths = sanityItems.map((item) => ({
    params: { slug: item.slug.current },
    props: {
      portfolio: {
        title: item.title,
        date: item.date
          ? new Date(item.date).toLocaleDateString("pl-PL", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })
          : "",
        category: item.category || "reportaz-slubny",
        venue: item.venue || null,
        coverImage: item.coverImage
          ? urlFor(item.coverImage).width(1400).quality(90).url()
          : null,
        images: item.images
          ? item.images.map((img: any) => ({
              src: urlFor(img).width(1400).quality(90).url(),
              srcset: `${urlFor(img).width(400).quality(80).url()} 400w, ${urlFor(img).width(800).quality(85).url()} 800w, ${urlFor(img).width(1400).quality(90).url()} 1400w`,
            }))
          : [],
      },
    },
  }));

  // Build paths from fallback data
  const fallbackPaths = Object.entries(fallbackData).map(([slug, data]) => ({
    params: { slug },
    props: { portfolio: data },
  }));

  // Merge: Sanity paths first, then fallback paths that don't exist in Sanity
  const existingSlugs = new Set(sanityPaths.map((p) => p.params.slug));
  const uniqueFallbackPaths = fallbackPaths.filter(
    (p) => !existingSlugs.has(p.params.slug),
  );

  return [...sanityPaths, ...uniqueFallbackPaths];
}

const { portfolio } = Astro.props;

if (!portfolio) {
  return Astro.redirect("/portfolio");
}

const catLabel = categoryLabels[portfolio.category] || portfolio.category;
const venue = portfolio.venue?.venueName;

const seoTitle = venue
  ? `${catLabel} ${venue} — ${portfolio.title} | Fiodorow`
  : `${catLabel} — ${portfolio.title} | Fiodorow Photography`;

const seoDescription = venue
  ? `${catLabel}: ${portfolio.title}${portfolio.date ? `, ${portfolio.date}` : ""} w ${venue}. Zobacz galerię zdjęć. Duet fotografów Fiodorow Photography.`
  : `${catLabel}: ${portfolio.title}${portfolio.date ? `, ${portfolio.date}` : ""}. Zobacz galerię zdjęć. Duet fotografów Fiodorow Photography.`;

const imageGallerySchema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: `${catLabel} — ${portfolio.title}`,
  description: seoDescription,
  url: `https://fiodorowphotography.pl/portfolio/${Astro.params.slug}`,
  ...(venue && {
    contentLocation: {
      "@type": "Place",
      name: venue,
      address: {
        "@type": "PostalAddress",
        addressLocality: venue,
        addressCountry: "PL",
      },
    },
  }),
  ...(portfolio.date && { datePublished: portfolio.date }),
  author: {
    "@type": "Organization",
    name: "Fiodorow Photography",
    url: "https://fiodorowphotography.pl",
  },
  image: portfolio.images.map((img: any) => img.src),
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={portfolio.coverImage || "/og-image.jpg"}
  breadcrumbs={[
    { name: "Portfolio", href: "/portfolio" },
    { name: portfolio.title, href: `/portfolio/${Astro.params.slug}` },
  ]}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(imageGallerySchema)}
  />

  <Header currentPath="/portfolio" />

  <!-- Portfolio Detail -->
  <section class="pt-32 pb-20 md:pt-40 md:pb-32 bg-cream">
    <div class="max-w-6xl mx-auto px-6 md:px-12">
      <!-- Header Section -->
      <div class="text-center mb-16 md:mb-20">
        <span
          class="inline-block text-[0.65rem] tracking-[0.25em] uppercase text-charcoal-light mb-4 px-4 py-2 border border-charcoal/20"
        >
          {categoryLabels[portfolio.category] || portfolio.category}
        </span>
        <h1
          class="font-serif text-4xl md:text-5xl lg:text-6xl tracking-[0.1em] uppercase text-charcoal mt-4 mb-6"
        >
          {portfolio.title}
        </h1>
        <p class="font-serif text-lg text-olive italic mb-4">
          {portfolio.date}
        </p>
        {
          portfolio.venue?.venueName && (
            <div class="mb-10">
              {portfolio.venue.venueUrl ? (
                <a
                  href={portfolio.venue.venueUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm text-charcoal-light hover:text-olive transition-colors duration-300 group"
                >
                  <svg
                    class="w-4 h-4 text-olive"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  <span class="group-hover:underline underline-offset-4">
                    {portfolio.venue.venueName}
                  </span>
                  <svg
                    class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </a>
              ) : (
                <span class="inline-flex items-center gap-2 text-sm text-charcoal-light">
                  <svg
                    class="w-4 h-4 text-olive"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                  </svg>
                  {portfolio.venue.venueName}
                </span>
              )}
            </div>
          )
        }

        <!-- Mobile hint -->
        <p
          class="text-charcoal-light/50 text-[0.6rem] tracking-[0.1em] uppercase mb-8 lg:hidden"
        >
          🔍 Kliknij zdjęcie, aby powiększyć
        </p>

        <!-- Image Grid - Masonry Style (Row-ordered via JS) -->
        <div id="gallery-grid" class="columns-1 md:columns-2 gap-4 space-y-4">
          {
            portfolio.images.map((image: any, index: number) => (
              <div
                class="break-inside-avoid overflow-hidden cursor-pointer gallery-item relative group"
                data-index={index}
              >
                <img
                  src={image.src}
                  srcset={image.srcset}
                  sizes="(max-width: 768px) 100vw, 50vw"
                  alt={`${categoryLabels[portfolio.category] || portfolio.category} ${portfolio.title}${portfolio.venue?.venueName ? ` — ${portfolio.venue.venueName}` : ""}, zdjęcie ${index + 1}`}
                  class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
                  loading={index < 5 ? "eager" : "lazy"}
                  width="800"
                  height="1200"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />
              </div>
            ))
          }
        </div>

        <script is:inline>
          (function() {
            function initMasonry() {
              var grid = document.getElementById('gallery-grid');
              if (!grid) return;

              var items = Array.from(grid.querySelectorAll('.gallery-item'));
              if (!items.length) return;

              var width = window.innerWidth;
              var numCols = width >= 768 ? 2 : 1;

              // Skip if column count hasn't changed
              if (grid.dataset.cols === String(numCols)) return;
              grid.dataset.cols = String(numCols);

              // Detach items before clearing
              items.forEach(function(item) {
                item.style.marginTop = '';
              });

              // Reset grid
              grid.className = '';
              grid.innerHTML = '';

              if (numCols === 1) {
                grid.style.cssText = 'display:flex;flex-direction:column;gap:1rem';
                items.forEach(function(item) { grid.appendChild(item); });
                return;
              }

              grid.style.cssText = 'display:flex;gap:1rem';

              var columns = [];
              for (var i = 0; i < numCols; i++) {
                var col = document.createElement('div');
                col.style.cssText = 'flex:1;display:flex;flex-direction:column;gap:1rem';
                grid.appendChild(col);
                columns.push(col);
              }

              // Round-robin: items go row by row across columns
              items.forEach(function(item, i) {
                columns[i % numCols].appendChild(item);
              });
            }

            initMasonry();
            var timer;
            window.addEventListener('resize', function() {
              clearTimeout(timer);
              timer = setTimeout(initMasonry, 150);
            });
          })();
        </script>

        <!-- Navigation -->
        <div
          class="mt-16 pt-8 border-t border-charcoal/10 flex flex-col sm:flex-row justify-between items-center gap-4"
        >
          <a href="/portfolio" class="btn-primary"> ← Powrót do Portfolio </a>
          <a href="/kontakt" class="btn-primary"> Zarezerwuj termin </a>
        </div>
      </div>
    </div>

    <!-- Lightbox -->
    <div
      id="lightbox"
      class="fixed inset-0 bg-black/95 z-50 hidden items-center justify-center select-none"
    >
      <button
        id="lightbox-close"
        class="absolute top-4 right-4 text-white/70 hover:text-white transition-colors z-20 p-3"
        aria-label="Zamknij"
        style="touch-action:manipulation;"
      >
        <svg
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <button
        id="lightbox-prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-20 p-4"
        aria-label="Poprzednie"
        style="touch-action:manipulation;"
      >
        <svg
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        id="lightbox-next"
        class="absolute right-0 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-20 p-4"
        aria-label="Następne"
        style="touch-action:manipulation;"
      >
        <svg
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <div id="lightbox-track" class="absolute inset-0 z-10 overflow-hidden">
        <img
          id="lightbox-img-a"
          src=""
          alt=""
          class="absolute top-1/2 left-1/2 max-w-[90vw] max-h-[85vh] object-contain"
          style="transform:translate(-50%,-50%);pointer-events:none;"
          draggable="false"
        />
        <img
          id="lightbox-img-b"
          src=""
          alt=""
          class="absolute top-1/2 left-1/2 max-w-[90vw] max-h-[85vh] object-contain"
          style="transform:translate(-50%,-50%);pointer-events:none;opacity:0;"
          draggable="false"
        />
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/50 text-xs tracking-wider z-20">
        <span id="lightbox-counter"></span>
      </div>
    </div>

    <Footer />
  </section>

  <script define:vars={{ images: portfolio.images.map((img: any) => img.src) }}>
    var galleryItems = document.querySelectorAll(".gallery-item");
    var lightbox = document.getElementById("lightbox");
    var imgA = document.getElementById("lightbox-img-a");
    var imgB = document.getElementById("lightbox-img-b");
    var lightboxTrack = document.getElementById("lightbox-track");
    var lightboxCounter = document.getElementById("lightbox-counter");
    var closeBtn = document.getElementById("lightbox-close");
    var prevBtn = document.getElementById("lightbox-prev");
    var nextBtn = document.getElementById("lightbox-next");

    var currentIndex = 0;
    var scrollY = 0;
    var isAnimating = false;
    // activeImg is the currently visible image element
    var activeImg = imgA;

    function pos(el, x) {
      el.style.transform = "translate(calc(-50% + " + x + "px), -50%)";
    }

    function updateCounter() {
      if (lightboxCounter) lightboxCounter.textContent = (currentIndex + 1) + " / " + images.length;
    }

    function openLightbox(index) {
      currentIndex = index;
      activeImg = imgA;
      imgA.src = images[index];
      imgA.style.opacity = "1";
      imgA.style.transition = "none";
      pos(imgA, 0);
      imgB.style.opacity = "0";
      imgB.src = "";
      updateCounter();
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      scrollY = window.scrollY;
      document.body.style.position = "fixed";
      document.body.style.top = "-" + scrollY + "px";
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.overflow = "";
      window.scrollTo(0, scrollY);
    }

    function goTo(newIndex, direction, swipeOffset) {
      if (isAnimating) return;
      isAnimating = true;

      var outImg = activeImg;
      var inImg = (activeImg === imgA) ? imgB : imgA;
      var w = window.innerWidth;
      var exitDist = w * 0.55;
      var fromSwipe = typeof swipeOffset === "number";

      // Preload next image into incoming element
      currentIndex = newIndex;
      inImg.src = images[currentIndex];
      updateCounter();

      // Calculate proportional duration for swipe (shorter if already dragged far)
      var dur;
      if (fromSwipe) {
        var remaining = exitDist - Math.abs(swipeOffset);
        dur = Math.max(0.15, 0.3 * (remaining / exitDist));
      } else {
        dur = 0.3;
      }
      var durStr = dur.toFixed(2) + "s";
      var ease = "cubic-bezier(0.25, 0.1, 0.25, 1)";

      // Position incoming off-screen on the entry side
      inImg.style.transition = "none";
      inImg.style.opacity = "1";
      pos(inImg, direction * exitDist);

      // Commit current state of both images before animating
      if (fromSwipe) {
        outImg.style.transition = "none";
      }
      void inImg.offsetWidth;
      void outImg.offsetWidth;

      // Animate both simultaneously
      outImg.style.transition = "transform " + durStr + " " + ease + ", opacity " + durStr + " " + ease;
      inImg.style.transition = "transform " + durStr + " " + ease;

      pos(outImg, -direction * exitDist);
      outImg.style.opacity = "0";
      pos(inImg, 0);

      activeImg = inImg;

      var timeoutMs = Math.ceil(dur * 1000) + 20;
      setTimeout(function() {
        outImg.style.transition = "none";
        outImg.src = "";
        isAnimating = false;
      }, timeoutMs);
    }

    function showPrev() { goTo((currentIndex - 1 + images.length) % images.length, -1); }
    function showNext() { goTo((currentIndex + 1) % images.length, 1); }

    galleryItems.forEach(function(item) {
      item.addEventListener("click", function() {
        openLightbox(parseInt(item.getAttribute("data-index") || "0"));
      });
    });

    closeBtn?.addEventListener("click", function(e) { e.stopPropagation(); closeLightbox(); });
    prevBtn?.addEventListener("click", function(e) { e.stopPropagation(); showPrev(); });
    nextBtn?.addEventListener("click", function(e) { e.stopPropagation(); showNext(); });

    // Lightbox closes only via X button or Escape key

    document.addEventListener("keydown", function(e) {
      if (lightbox?.classList.contains("hidden")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") showPrev();
      if (e.key === "ArrowRight") showNext();
    });

    // ---- Touch swipe ----
    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var swiping = false;
    var swipeLocked = false;

    lightboxTrack?.addEventListener("touchstart", function(e) {
      if (isAnimating || e.touches.length !== 1) return;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      swiping = false;
      swipeLocked = false;
      activeImg.style.transition = "none";
    }, { passive: true });

    lightboxTrack?.addEventListener("touchmove", function(e) {
      if (isAnimating || swipeLocked || e.touches.length !== 1) return;
      var dx = e.touches[0].clientX - touchStartX;

      if (!swiping) {
        var absDx = Math.abs(dx);
        var absDy = Math.abs(e.touches[0].clientY - touchStartY);
        if (absDy > 10 && absDy > absDx) {
          swipeLocked = true; // vertical scroll, ignore
          return;
        }
        if (absDx > 10) {
          swiping = true;
        } else {
          return;
        }
      }

      if (e.cancelable) e.preventDefault();
      touchDeltaX = dx;
      pos(activeImg, dx);
    }, { passive: false });

    lightboxTrack?.addEventListener("touchend", function() {
      if (!swiping || isAnimating) return;
      swiping = false;
      var threshold = window.innerWidth * 0.12;

      if (touchDeltaX < -threshold) {
        // Swiped left → next image
        goTo((currentIndex + 1) % images.length, 1, touchDeltaX);
      } else if (touchDeltaX > threshold) {
        // Swiped right → previous image
        goTo((currentIndex - 1 + images.length) % images.length, -1, touchDeltaX);
      } else {
        activeImg.style.transition = "transform 0.2s ease-out";
        pos(activeImg, 0);
      }
    }, { passive: true });
  </script>
</BaseLayout>
