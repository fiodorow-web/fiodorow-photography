---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getPortfolioItems, urlFor, categoryLabels } from "../../lib/sanity";

// Fetch from Sanity
let sanityItems: any[] = [];
try {
  sanityItems = await getPortfolioItems();
} catch (e) {
  console.log("Sanity fetch failed, using fallback data");
}

// Fallback static data (used when Sanity is empty)
const fallbackItems = [
  {
    image:
      "https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=800&q=80",
    category: "reportaz-slubny",
    title: "Joanna & Darek",
    slug: { current: "joanna-darek" },
    date: "2024-06-08",
  },
  {
    image:
      "https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=800&q=80",
    category: "sesja-narzeczenska",
    title: "Natalia & Michał",
    slug: { current: "natalia-michal" },
    date: "2024-05-15",
  },
  {
    image:
      "https://images.unsplash.com/photo-1606216794074-735e91aa2c92?w=800&q=80",
    category: "reportaz-slubny",
    title: "Amelia & Damian",
    slug: { current: "amelia-damian" },
    date: "2024-07-22",
  },
  {
    image:
      "https://images.unsplash.com/photo-1519741497674-611481863552?w=800&q=80",
    category: "sesja-poslubna",
    title: "Karolina & Piotr",
    slug: { current: "karolina-piotr" },
    date: "2024-08-10",
  },
];

// Use Sanity data if available, otherwise fallback
const portfolioItems =
  sanityItems.length > 0
    ? sanityItems.map((item) => ({
        image: item.coverImage
          ? urlFor(item.coverImage).width(800).quality(80).url()
          : fallbackItems[0].image,
        category: item.category,
        title: item.title,
        slug: item.slug,
        date: item.date,
      }))
    : fallbackItems;

const categories = [
  "Wszystkie",
  "Reportaż ślubny",
  "Sesja narzeczeńska",
  "Sesja poślubna",
];
---

<BaseLayout
  title="Portfolio — Fotograf Ślubny Siedlce | Fiodorow Photography"
  description="Reportaże ślubne, sesje narzeczeńskie i poślubne. Zobacz portfolio Fiodorow Photography — fotograf Siedlce, Białystok, Warszawa."
  breadcrumbs={[{ name: "Portfolio", href: "/portfolio" }]}
>
  <Header currentPath="/portfolio" />

  <!-- Portfolio Section -->
  <section class="pt-32 pb-20 md:pt-40 md:pb-32 bg-cream">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <!-- Title -->
      <div class="text-center mb-16 reveal reveal-up">
        <h1
          class="font-serif text-3xl md:text-4xl tracking-[0.2em] uppercase text-charcoal mb-4"
        >
          Nasze <i class="font-light italic text-olive">Portfolio</i>
        </h1>
        <p class="text-charcoal-light text-sm md:text-base max-w-md mx-auto">
          Każda para to inna historia. <br>
          Zajrzyjcie do środka i zobaczcie, jak je opowiadamy.
        </p>
      </div>

      <!-- Category Filter -->
      <div
        class="flex flex-wrap justify-center gap-3 md:gap-4 mb-16 reveal reveal-up reveal-d1"
        id="category-filter"
      >
        {
          categories.map((cat, index) => (
            <button
              class:list={[
                "category-btn px-4 py-2 text-[0.65rem] md:text-xs tracking-[0.15em] uppercase transition-all duration-300 border",
                index === 0
                  ? "active bg-charcoal text-white border-charcoal"
                  : "bg-transparent border-charcoal/20 text-charcoal hover:border-charcoal hover:bg-charcoal/5",
              ]}
              data-category={cat === "Wszystkie" ? "all" : cat}
            >
              {cat}
            </button>
          ))
        }
      </div>

      <!-- Symmetric 3-Column Portfolio Grid -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 reveal-stagger"
        id="portfolio-grid"
      >
        {
          portfolioItems.map((item, index) => (
            <a
              href={`/portfolio/${item.slug.current}`}
              class="portfolio-card group relative overflow-hidden block reveal reveal-scale"
              data-category={categoryLabels[item.category] || item.category}
            >
              <div class="relative aspect-[3/4] overflow-hidden">
                <img
                  src={item.image}
                  alt={`${categoryLabels[item.category] || item.category} ${item.title} — fotograf Siedlce`}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
                  loading={index < 3 ? "eager" : "lazy"}
                />

                <!-- Always-visible bottom gradient -->
                <div class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none"></div>
                
                <!-- Desktop hover overlay -->
                <div class="absolute inset-0 bg-black/15 opacity-0 lg:group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />

                <!-- Desktop centered plus icon -->
                <div class="absolute inset-0 hidden lg:flex items-center justify-center pointer-events-none">
                    <span class="text-white text-4xl font-light opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all duration-500">+</span>
                </div>

                <!-- Bottom Text (always visible) -->
                <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6 text-left z-10">
                  <span class="text-[0.6rem] md:text-[0.65rem] tracking-[0.25em] uppercase text-white/80 block mb-1">
                    {categoryLabels[item.category] || item.category}
                  </span>
                  <h3 class="font-serif text-lg md:text-xl tracking-[0.1em] uppercase text-white">
                    {item.title}
                  </h3>
                  <!-- Desktop: "Zobacz sesję" label on hover -->
                  <span class="hidden lg:inline-block mt-2 text-[0.6rem] tracking-[0.2em] uppercase text-white/0 group-hover:text-white/90 border-b border-white/0 group-hover:border-white/60 pb-0.5 transition-all duration-500 delay-100">Zobacz sesję →</span>
                  <!-- Mobile: always-visible hint -->
                  <span class="lg:hidden block mt-2 text-[0.55rem] tracking-[0.15em] uppercase text-white/60">Kliknij aby zobaczyć →</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="section-title mb-6 reveal reveal-up">
        Podoba Wam się to, co <i class="font-light italic text-olive">widzicie</i>?
      </h2>
      <p
        class="text-charcoal-light text-sm md:text-base leading-relaxed mb-10 max-w-xl mx-auto reveal reveal-up reveal-d1"
      >
        Porozmawiajmy o tym, jak uwiecznić Wasz wyjątkowy dzień.
        Napiszcie lub zadzwońcie — chętnie poznamy Waszą historię.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-up reveal-d2">
        <a href="/kontakt" class="btn-primary">
          Napisz do nas
        </a>
        <a href="tel:+48660872121" class="btn-primary border-charcoal text-charcoal hover:bg-charcoal hover:text-white">
          Zadzwoń: 660 872 121
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll(".category-btn");
  const portfolioItems = document.querySelectorAll("#portfolio-grid > a");

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      // Update active state
      filterBtns.forEach((b) => {
        b.classList.remove(
          "active",
          "bg-charcoal",
          "text-white",
          "border-charcoal",
        );
        b.classList.add(
          "bg-transparent",
          "border-charcoal/20",
          "text-charcoal",
        );
      });
      btn.classList.add(
        "active",
        "bg-charcoal",
        "text-white",
        "border-charcoal",
      );
      btn.classList.remove("bg-transparent", "border-charcoal/20");

      const category = btn.getAttribute("data-category");

      portfolioItems.forEach((item) => {
        const itemCategory = item.getAttribute("data-category");

        if (category === "all" || itemCategory === category) {
          (item as HTMLElement).style.display = "block";
          setTimeout(() => {
            (item as HTMLElement).style.opacity = "1";
            (item as HTMLElement).style.transform = "translateY(0)";
          }, 50);
        } else {
          (item as HTMLElement).style.opacity = "0";
          (item as HTMLElement).style.transform = "translateY(20px)";
          setTimeout(() => {
            (item as HTMLElement).style.display = "none";
          }, 300);
        }
      });
    });
  });
</script>
